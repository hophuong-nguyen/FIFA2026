{
  "version": 2,
  "builds": [
      { "src": "index.html", "use": "@vercel/static" },
      { "src": "summary.html", "use": "@vercel/static" }
    ],
  "rewrites": [
    { "source": "/summary", "destination": "/summary.html" },
    { "source": "/(.*)", "destination": "/index.html" }
  ] 
}